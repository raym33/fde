# Core mode
DEMO_MODE=true
ENVIRONMENT=development
DATA_REGION=eu

# Search provider: auto | brave | tavily | perplexity | demo
# Set DEMO_MODE=false to call real providers.
SEARCH_PROVIDER=auto
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
PERPLEXITY_API_KEY=
WEB_SEARCH_TIMEOUT_SECONDS=10
WEB_SEARCH_CACHE_TTL_SECONDS=900
WEB_SEARCH_DEFAULT_COUNTRY=ES
WEB_SEARCH_DEFAULT_LANGUAGE=es

# Document extraction
# OCR requires the system `tesseract` binary. If absent, PDF/DOCX text extraction still works.

# LLM providers via LiteLLM
DEEPINFRA_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

MODEL_ROUTER_CHEAP=deepinfra/meta-llama/Meta-Llama-3.1-8B-Instruct
MODEL_ROUTER_MEDIUM=deepinfra/Qwen/Qwen3-235B-A22B
MODEL_ROUTER_PREMIUM=anthropic/claude-sonnet-4-6
MODEL_EMBEDDINGS=deepinfra/BAAI/bge-m3

# Local/LAN inference via LM Studio OpenAI-compatible server
# Local Mac default: http://127.0.0.1:1234/v1
# Other machines on LAN: use http://192.168.x.y:1234/v1 and enable network serving in LM Studio.
LOCAL_LLM_ENABLED=false
LOCAL_LLM_PROVIDER=lmstudio
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_API_KEY=lm-studio
LM_STUDIO_TIMEOUT_SECONDS=120
LM_STUDIO_CHAT_MODEL=gemma-4-26b-a4b-it-mlx
LM_STUDIO_MODEL_CHEAP=qwen3.6-27b
LM_STUDIO_MODEL_MEDIUM=gemma-4-26b-a4b-it-mlx
LM_STUDIO_MODEL_PREMIUM=gemma-4-26b-a4b-it-mlx
LM_STUDIO_EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
LM_STUDIO_REMOTE_BASE_URLS=
LOCAL_EMBEDDING_FALLBACK=true

# Infrastructure
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/virtudirector
REDIS_URL=redis://localhost:6379/0
LABS_SQLITE_PATH=
JWT_SECRET=dev-secret-change-me
ADMIN_BASIC_USERNAME=admin
ADMIN_BASIC_PASSWORD=change-me-admin
